<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Theme Section -->
        <TextView
            android:id="@+id/tv_theme_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/theme_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_emerald"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/emerald_bg">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/theme_emerald"
                    android:textColor="@color/emerald_accent"
                    android:gravity="center"
                    android:textSize="10sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_midnight"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/midnight_bg">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/theme_midnight"
                    android:textColor="@color/midnight_accent"
                    android:gravity="center"
                    android:textSize="10sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_purple"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/purple_bg">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/theme_purple"
                    android:textColor="@color/purple_accent"
                    android:gravity="center"
                    android:textSize="10sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_desert"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:layout_margin="3dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/desert_bg">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/theme_desert"
                    android:textColor="@color/desert_accent"
                    android:gravity="center"
                    android:textSize="10sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Font Size Section -->
        <TextView
            android:id="@+id/tv_arabic_size_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/arabic_font_size"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_arabic_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="20"
            android:valueTo="60"
            android:stepSize="2"
            android:value="36"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_trans_size_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/translation_font_size"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_translation_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="12"
            android:valueTo="36"
            android:stepSize="2"
            android:value="18"
            android:layout_marginBottom="20dp" />

        <!-- Translations Section -->
        <TextView
            android:id="@+id/tv_translations_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/translations"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_translations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="20dp" />

        <!-- Tafseers Section -->
        <TextView
            android:id="@+id/tv_tafseers_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tafseers"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tafseers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="20dp" />

        <!-- Word by Word Section -->
        <TextView
            android:id="@+id/tv_wbw_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/word_by_word"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_wbw"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="20dp" />

        <!-- Audio Section -->
        <TextView
            android:id="@+id/tv_audio_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/audio"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <Spinner
                android:id="@+id/spinner_audio_surah"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download_audio"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/download_audio"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Bookmarks Section -->
        <TextView
            android:id="@+id/tv_bookmarks_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bookmarks"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_no_bookmarks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_bookmarks"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_bookmarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="20dp" />

        <!-- Vocabulary Builder -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_vocabulary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vocabulary_builder"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_marginBottom="16dp" />

        <!-- Language -->
        <TextView
            android:id="@+id/tv_language_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/language"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_language"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
