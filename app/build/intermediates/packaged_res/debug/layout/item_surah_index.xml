<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/surah_item_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:background="?attr/selectableItemBackground">

    <!-- Number circle -->
    <TextView
        android:id="@+id/tv_number"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_surah_number_circle" />

    <!-- Middle: Names -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_name_en"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tv_meaning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <!-- Metadata row: revelation type + ayah count -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <ImageView
                android:id="@+id/iv_revelation"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_meccan" />

            <TextView
                android:id="@+id/tv_revelation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginStart="3dp" />

            <TextView
                android:id="@+id/tv_ayah_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginStart="12dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Arabic name (right side) -->
    <TextView
        android:id="@+id/tv_name_ar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textDirection="rtl" />

</LinearLayout>
