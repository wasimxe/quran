<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/learn_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <!-- Title + Stats -->
    <TextView
        android:id="@+id/tv_learn_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/learn_title"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_progress_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:layout_marginStart="8dp"
        android:gravity="end"
        app:layout_constraintTop_toTopOf="@id/tv_learn_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_learn_title"
        app:layout_constraintStart_toEndOf="@id/tv_learn_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_learn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tv_learn_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mode tabs: Word List | Flashcard -->
    <LinearLayout
        android:id="@+id/learn_tabs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_mode_pill"
        app:layout_constraintTop_toBottomOf="@id/progress_learn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btn_tab_wordlist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/learn_word_list"
            android:textSize="13sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="5dp"
            android:background="@drawable/bg_mode_pill_active" />

        <TextView
            android:id="@+id/btn_tab_flashcard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/learn_flashcard"
            android:textSize="13sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="5dp" />
    </LinearLayout>

    <!-- Filter Chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/filter_chips"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintTop_toBottomOf="@id/learn_tabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/learn_all"
            android:checked="true"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_known"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/learn_known_words"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_unknown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/learn_unknown_words"
            style="@style/Widget.Material3.Chip.Filter" />
    </com.google.android.material.chip.ChipGroup>

    <!-- WORD LIST VIEW (default) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_word_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/filter_chips"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- FLASHCARD VIEW (hidden by default) -->
    <LinearLayout
        android:id="@+id/flashcard_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/filter_chips"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Flashcard -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_flashcard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tv_learn_arabic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="48sp"
                    android:textDirection="rtl"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_learn_translation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:visibility="invisible" />

                <TextView
                    android:id="@+id/tv_learn_transliteration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:visibility="invisible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reveal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/learn_reveal"
                    android:layout_marginTop="20dp"
                    app:cornerRadius="20dp"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Know / Don't Know Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dont_know"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/learn_unknown"
                android:layout_marginEnd="6dp"
                android:textSize="13sp"
                app:cornerRadius="22dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_know"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/learn_known"
                android:layout_marginStart="6dp"
                android:textSize="13sp"
                app:cornerRadius="22dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
