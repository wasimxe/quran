<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/learn_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Top bar: Progress (left) + Title (right) + Close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layoutDirection="ltr"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tv_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_learn_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Learn Mode"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="end" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close" />
    </LinearLayout>

    <!-- Progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_learn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp" />

    <!-- Scope selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp">

        <Spinner
            android:id="@+id/spinner_scope"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Flashcard area: current word detail -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_flashcard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginVertical="4dp"
        app:cardCornerRadius="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">

            <!-- Large Arabic word -->
            <TextView
                android:id="@+id/tv_learn_arabic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="38sp"
                android:textDirection="rtl"
                android:gravity="center" />

            <!-- Frequency -->
            <TextView
                android:id="@+id/tv_learn_freq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <!-- Translation -->
            <TextView
                android:id="@+id/tv_learn_translation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textDirection="rtl"
                android:textAlignment="center"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginTop="6dp"
                android:visibility="invisible" />

            <!-- Action buttons: Reveal / Know / Don't -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_dont_know"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="✗ Don't"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="20dp"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reveal"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Reveal"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="20dp"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_know"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="✓ Know"
                    android:textSize="12sp"
                    app:cornerRadius="20dp" />
            </LinearLayout>

            <!-- Prev/Next navigation + Search -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_prev_word"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="◄ Prev"
                    android:textSize="11sp"
                    app:cornerRadius="18dp"
                    style="@style/Widget.Material3.Button.TextButton" />

                <TextView
                    android:id="@+id/tv_word_index"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:paddingHorizontal="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_next_word"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Next ►"
                    android:textSize="11sp"
                    app:cornerRadius="18dp"
                    style="@style/Widget.Material3.Button.TextButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_search_word"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Search"
                    android:textSize="11sp"
                    app:icon="@drawable/ic_search"
                    app:iconSize="16dp"
                    app:cornerRadius="18dp"
                    style="@style/Widget.Material3.Button.TextButton" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Filter Chips + Reset -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/filter_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:chipSpacingHorizontal="4dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Words"
            android:checked="true"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_unknown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unknown"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_known"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Known"
            style="@style/Widget.Material3.Chip.Filter" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset"
            android:textSize="11sp"
            style="@style/Widget.Material3.Chip.Assist" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Word list (scrollable) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_word_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>
