<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sheet_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="16dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_mode_pill"
        android:layout_marginBottom="12dp" />

    <!-- Ayah reference -->
    <TextView
        android:id="@+id/tv_ayah_ref"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="4dp" />

    <!-- Arabic text -->
    <TextView
        android:id="@+id/tv_arabic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textDirection="rtl"
        android:textAlignment="center"
        android:lineSpacingMultiplier="1.4"
        android:includeFontPadding="true"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22888888"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Filter chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/filter_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="4dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_all"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All"
            android:checked="true"
            android:textSize="13sp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_translations"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Translations"
            android:textSize="13sp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_tafseers"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tafseers"
            android:textSize="13sp" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Scrollable translations list -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp">

        <LinearLayout
            android:id="@+id/translations_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp" />

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
