<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Compact Top Header -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_compact"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: Surah name + Ayah counter + Juz + Bookmark -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Surah name (tappable) -->
            <TextView
                android:id="@+id/tv_surah_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:drawablePadding="4dp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- Ayah counter (tappable) -->
            <TextView
                android:id="@+id/tv_ayah_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:minWidth="48dp"
                android:gravity="center" />

            <!-- Juz badge -->
            <TextView
                android:id="@+id/tv_juz_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:background="@drawable/bg_juz_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="4dp" />

            <!-- Bookmark -->
            <ImageButton
                android:id="@+id/btn_bookmark"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_bookmark"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/bookmark"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <!-- Row 2: Mode Toggle Pill (centered) -->
        <LinearLayout
            android:id="@+id/mode_toggle_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:background="@drawable/bg_mode_pill"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/btn_mode_reading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_reading"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="5dp"
                android:background="@drawable/bg_mode_pill_active" />

            <TextView
                android:id="@+id/btn_mode_learning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_learning"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="5dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Source selector (Learning mode only) -->
    <LinearLayout
        android:id="@+id/source_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/header_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Source type chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/source_chips"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="4dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_translation"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="@string/mode_translation"
                android:textSize="12sp"
                android:checked="true"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_tafseer"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="@string/mode_tafseer"
                android:textSize="12sp"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_wbw"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="@string/mode_wbw"
                android:textSize="12sp"
                style="@style/Widget.Material3.Chip.Filter" />
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <!-- Source edition selector (Learning mode only) -->
    <Spinner
        android:id="@+id/spinner_source"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_marginHorizontal="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/source_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ViewPager2 for ayah swiping -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewpager_ayah"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/spinner_source"
        app:layout_constraintBottom_toTopOf="@id/floating_toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Floating Mini Toolbar -->
    <LinearLayout
        android:id="@+id/floating_toolbar"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_floating_toolbar"
        android:elevation="6dp"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_previous"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_prev"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/previous"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <ImageButton
            android:id="@+id/btn_play"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/play"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:layout_marginStart="4dp" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_next"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/next"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:layout_marginStart="4dp" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#44FFFFFF"
            android:layout_marginHorizontal="6dp" />

        <ImageButton
            android:id="@+id/btn_repeat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_repeat"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/repeat"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:alpha="0.5" />

        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/share"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:layout_marginStart="2dp" />

        <ImageButton
            android:id="@+id/btn_random"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_shuffle"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/random"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:layout_marginStart="2dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
