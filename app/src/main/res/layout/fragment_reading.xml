<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Compact Top Header -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_compact"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: Surah name + Ayah counter + Juz + Bookmark -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Surah name (tappable) -->
            <TextView
                android:id="@+id/tv_surah_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:drawablePadding="4dp"
                android:padding="6dp"
                android:contentDescription="@string/cd_surah_name"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- Ayah counter (tappable) -->
            <TextView
                android:id="@+id/tv_ayah_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_ayah_counter"
                android:minWidth="48dp"
                android:gravity="center" />

            <!-- Juz badge -->
            <TextView
                android:id="@+id/tv_juz_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:background="@drawable/bg_juz_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="4dp" />

            <!-- Bookmark -->
            <ImageButton
                android:id="@+id/btn_bookmark"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_bookmark"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/bookmark"
                android:scaleType="centerInside"
                android:padding="6dp"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <!-- Row 2: Display Mode Buttons (instant switching) -->
        <LinearLayout
            android:id="@+id/mode_toggle_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@drawable/bg_mode_pill"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/btn_mode_arabic"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Arabic"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingVertical="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/btn_mode_translation"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Translation"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingVertical="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/btn_mode_tafseer"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tafseer"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingVertical="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/btn_mode_wbw"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="WBW"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingVertical="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>
    </LinearLayout>

    <!-- Source edition selector (for translation/tafseer/wbw switching) -->
    <Spinner
        android:id="@+id/spinner_source"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_marginHorizontal="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/header_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Continuous scrolling ayah list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_ayahs"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/spinner_source"
        app:layout_constraintBottom_toTopOf="@id/floating_toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Enhanced Floating Toolbar -->
    <LinearLayout
        android:id="@+id/floating_toolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_floating_toolbar"
        android:elevation="6dp"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Reciter name (hidden — select reciter via long press on play) -->
        <TextView
            android:id="@+id/tv_reciter_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:maxWidth="280dp"
            android:padding="2dp"
            android:contentDescription="@string/cd_reciter_name"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone" />

        <!-- Button row: all controls in one row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Go to reading point -->
            <ImageButton
                android:id="@+id/fab_reading_point"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_my_location"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Go to Reading Point"
                android:tooltipText="Reading Point"
                android:scaleType="centerInside"
                android:padding="4dp" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#44FFFFFF"
                android:layout_marginHorizontal="3dp" />

            <ImageButton
                android:id="@+id/btn_previous"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_skip_prev"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/previous"
                android:tooltipText="Previous"
                android:scaleType="centerInside"
                android:padding="4dp" />

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/play"
                android:tooltipText="Play / Pause"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:layout_marginStart="2dp" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_skip_next"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/next"
                android:tooltipText="Next"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:layout_marginStart="2dp" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#44FFFFFF"
                android:layout_marginHorizontal="3dp" />

            <ImageButton
                android:id="@+id/btn_repeat"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_repeat"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/repeat"
                android:tooltipText="Repeat"
                android:scaleType="centerInside"
                android:padding="3dp"
                android:alpha="0.5" />

            <!-- Speed button -->
            <TextView
                android:id="@+id/btn_speed"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="1x"
                android:textSize="11sp"
                android:paddingHorizontal="4dp"
                android:contentDescription="@string/cd_playback_speed"
                android:tooltipText="Playback Speed"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="2dp" />

            <ImageButton
                android:id="@+id/btn_share"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_share"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/share"
                android:tooltipText="Share"
                android:scaleType="centerInside"
                android:padding="3dp"
                android:layout_marginStart="2dp" />

            <ImageButton
                android:id="@+id/btn_random"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_shuffle"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/random"
                android:tooltipText="Random Ayah"
                android:scaleType="centerInside"
                android:padding="3dp"
                android:layout_marginStart="2dp" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#44FFFFFF"
                android:layout_marginHorizontal="3dp" />

            <!-- Learn mode -->
            <ImageButton
                android:id="@+id/fab_learn"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_learn"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Learn Mode"
                android:tooltipText="Learn Vocabulary"
                android:scaleType="centerInside"
                android:padding="4dp" />

            <!-- Fullscreen -->
            <ImageButton
                android:id="@+id/btn_fullscreen"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_fullscreen"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Full Screen"
                android:tooltipText="Full Screen"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:layout_marginStart="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Floating exit button (visible only in fullscreen) -->
    <ImageButton
        android:id="@+id/btn_exit_fullscreen"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_fullscreen_exit"
        android:background="@drawable/bg_floating_toolbar"
        android:elevation="6dp"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:alpha="0.7"
        android:visibility="gone"
        android:contentDescription="Exit Full Screen"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
